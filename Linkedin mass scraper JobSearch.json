    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Safety check if no results were found\nif (!items || items.length === 0) {\n  return [{\n    json: {\n      all_names: \"No results found\",\n      all_urls: \"No results found\"\n    }\n  }];\n}\n\nlet namesList = [];\nlet urlsList = [];\n\n// Helper function to clean up the Google Title into just a Name\nfunction extractName(rawTitle) {\n    if (!rawTitle) return \"Unknown\";\n    return rawTitle.split(/[-|,]/)[0].replace(/profiles/i, \"\").trim(); \n}\n\n// Loop through everyone and add them to our lists\nfor (const item of items) {\n    const name = extractName(item.json.title);\n    const url = item.json.link || \"No URL\";\n    \n    namesList.push(name);\n    urlsList.push(url);\n}\n\n// Output a single package. \n// We use \\n to create a new line between each person so it stacks neatly in your spreadsheet cell!\nreturn [{\n  json: {\n    all_names: namesList.join('\\n'),\n    all_urls: urlsList.join('\\n')\n  }\n}];"
      },
