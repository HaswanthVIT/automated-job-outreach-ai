    {
      "parameters": {
        "jsCode": "// Loop through all items\nfor (const item of $input.all()) {\n  try {\n    // 1. Get content (Handle different key names)\n    let content = item.json.message ? item.json.message.content : item.json.content;\n\n    if (content) {\n      // 2. Remove Markdown & Comments\n      content = content.replace(/```json/g, \"\").replace(/```/g, \"\");\n      content = content.replace(/\\/\\/.*$/gm, \"\"); // Remove comments\n\n      // 3. Extract JSON\n      const firstBrace = content.indexOf('{');\n      const lastBrace = content.lastIndexOf('}');\n\n      if (firstBrace !== -1 && lastBrace !== -1) {\n        content = content.substring(firstBrace, lastBrace + 1);\n        const parsed = JSON.parse(content);\n\n        // 4. Assign Parsed Fields to the Item (Updated for 5-point system)\n        item.json.resume_score = parsed.resume_match_score || 0;\n        item.json.company_score = parsed.company_type_score || 0;\n        item.json.type_score = parsed.employment_type_score || 0;\n        \n        // Calculate Total Score (Out of 5)\n        item.json.final_score = (item.json.resume_score + \n                                 item.json.company_score + \n                                 item.json.type_score);\n                                 \n        item.json.reasoning = parsed.reasoning || \"No reasoning provided\";\n        \n        // Cleanup the raw AI text from the final output to keep it neat\n        delete item.json.message;\n        delete item.json.content;\n      }\n    }\n  } catch (error) {\n    // If the AI fails to generate proper JSON, assign a 0 so the workflow doesn't crash\n    item.json.final_score = 0;\n    item.json.reasoning = \"Error parsing AI JSON: \" + error.message;\n  }\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
